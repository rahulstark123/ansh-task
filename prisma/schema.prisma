datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String?
  phone      String?
  firstName  String?
  lastName   String?
  avatar     String?
  bio        String?
  jobTitle   String?
  designation String?
  role       String   @default("editor")
  department String?
  timezone   String?
  language   String?
  reportsTo  String?
  acceptedTerms Boolean @default(false)
  dateOfBirth DateTime?
  bloodGroup  String?
  personalEmail String?
  emergencyContactName String?
  emergencyContactPhone String?
  employeeCode String?
  officeBranch String?
  workLocation String?
  joiningDate DateTime?
  employmentStatus String @default("Active")
  reportingHr String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brainboardNotes BrainboardNote[]
  sentMessages Message[]
  conversations ConversationParticipant[]
  channelMemberships ChannelMember[]
  taskNotes          TaskNote[]
  announcements      Announcement[]
}

model Workspace {
  id           Int      @id @default(autoincrement())
  name         String
  domain       String?
  logo         String?
  industry     String?
  size         String?
  website      String?
  billingEmail String?
  address      String?
  cityCountry  String?
  plan         String   @default("free") // "free" | "trial" | "pro"
  planExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Defaults
  defaultPriority String   @default("medium")
  defaultStatus   String   @default("todo")
  defaultCategory String   @default("General")
  defaultLabels   String[] @default([])
  customCategories String[] @default(["General", "Product", "Engineering", "Design", "Operations", "Marketing"])
  customLabels     String[] @default(["Bug", "Feature", "Improvement", "Docs", "Design", "Meeting"])
  kanbanColumnOrder String[] @default(["todo", "in_progress", "on_hold", "blocked", "done"])

  // Relationships
  users       User[]
  projects    Project[]
  tasks       Task[]
  roles       WorkspaceRole[]
  departments WorkspaceDepartment[]
  designations WorkspaceDesignation[]
  branches    WorkspaceBranch[]
  locations   WorkspaceLocation[]
  brainboardNotes BrainboardNote[]
  tickets     Ticket[]
  channels    Channel[]
  conversations Conversation[]
  subscriptions Subscription[]
  transactions  Transaction[]
  permissionSettings WorkspacePermissionSettings?
  announcements Announcement[]
}

model WorkspaceRole {
  id          String    @id @default(uuid())
  name        String
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, name])
}

model WorkspaceDepartment {
  id          String    @id @default(uuid())
  name        String
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, name])
}

model WorkspaceDesignation {
  id          String    @id @default(uuid())
  name        String
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, name])
}

model WorkspaceBranch {
  id          String    @id @default(uuid())
  name        String
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, name])
}

model WorkspaceLocation {
  id          String    @id @default(uuid())
  name        String
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, name])
}

model WorkspacePermissionSettings {
  id          String    @id @default(uuid())
  workspaceId Int       @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  matrix      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id             String   @id @default(uuid())
  name           String
  description    String?
  progress       Int      @default(0)
  startDate      DateTime @default(now())
  due            DateTime?
  priority       String   @default("Normal") // "Urgent" | "High" | "Normal" | "Low"
  status         String   @default("Active") // "Discovery" | "Planning" | "Active" | "Review" | "Completed" | "On Hold"
  health         String   @default("neutral") // "good" | "warn" | "danger" | "neutral"
  owner          String
  estimatedHours Int      @default(0)
  category       String
  members        String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationships
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  notes       String?
  due         String
  priority    String   @default("medium") // "low" | "medium" | "high"
  category    String?
  labels      String[] @default([])
  assignee    String?
  assignees   String[] @default([])
  status      String   @default("todo") // "todo" | "in_progress" | "on_hold" | "blocked" | "done"
  estimate    String?
  done        Boolean  @default(false)
  attachmentUrls String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskNotes   TaskNote[]
}

model TaskNote {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrainboardNote {
  id          String    @id @default(uuid())
  title       String
  body        String
  color       String
  x           Float
  y           Float
  rotation    Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id            String   @id @default(uuid())
  ticketId      String   @unique
  subject       String
  category      String   @default("Technical")
  priority      String   @default("Medium")
  status        String   @default("Open")
  description   String
  attachmentUrls String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  workspaceId   Int
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  replies       TicketReply[]
}

model TicketReply {
  id          String   @id @default(uuid())
  message     String
  authorRole  String   // "admin" | "user"
  authorName  String?
  authorEmail String?
  createdAt   DateTime @default(now())

  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model ContactUs {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contactus")
  @@index([createdAt])
  @@index([email])
}

model Channel {
  id          String    @id @default(uuid())
  name        String
  topic       String?
  isPrivate   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]
  members     ChannelMember[]
}

model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  workspaceId  Int
  workspace    Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(uuid())
  content        String
  createdAt      DateTime      @default(now())
  senderId       String
  sender         User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  channelId      String?
  channel        Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ChannelMember {
  id        String   @id @default(uuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([channelId, userId])
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  body        String
  pinned      Boolean  @default(false)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workspaceId, archived, pinned])
  @@index([workspaceId, createdAt])
}

model Subscription {
  id          String   @id @default(uuid())
  status      String   @default("PENDING") // "PENDING" | "SCHEDULED" | "ACTIVE" | "CANCELLED" | "EXPIRED"
  plan        String   @default("pro")
  seatsCount  Int      @default(1)
  amountPaisa Int
  billingCycle String  @default("monthly") // "monthly" | "yearly"
  startsAt    DateTime?
  expiresAt   DateTime?
  razorpayOrderId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id              String   @id @default(uuid())
  status          String   @default("CREATED") // "CREATED" | "SUCCESS" | "FAILED"
  amountPaisa     Int
  razorpayOrderId String
  razorpayPaymentId String?
  razorpaySignature String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId     Int
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}
